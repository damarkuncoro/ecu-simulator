{
  "name": "@ecu/cli-diag",
  "version": "0.1.0",
  "description": "CLI diagnostic tool for KWP2000/ISO9141 testing",
  "main": "dist/index.js",
  "dependencies": {
    "@ecu/transport-abstract": "workspace:*",
    "@ecu/logger": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test:integration": "jest --testPathPattern=integration",
    "test:hil": "jest --testPathPattern=hil",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}
