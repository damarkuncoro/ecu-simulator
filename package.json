{
  "name": "ecu-simulator",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade ECU simulator for KWP2000/ISO9141 diagnostic development",
  "workspaces": [
    "apps/*",
    "packages/*/*",
    "tools/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:hil": "turbo run test:hil",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "ecu:start": "node apps/cli-diag/dist/index.js",
    "ecu:start:tcp": "ECU_TRANSPORT=tcp node apps/cli-diag/dist/index.js",
    "ecu:start:serial": "ECU_TRANSPORT=serial node apps/cli-diag/dist/index.js",
    "setup:virtual-serial": "bash tools/scripts/setup-virtual-serial.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  }
}
