# ── ECU Simulator Environment Config ─────────────────────────────────────────
# Copy to .env.local and adjust values

# Transport mode: tcp | serial | websocket
ECU_TRANSPORT=tcp

# TCP / WebSocket config (used when ECU_TRANSPORT=tcp or websocket)
ECU_HOST=127.0.0.1
ECU_PORT=20000

# Serial / K-Line hardware config (used when ECU_TRANSPORT=serial)
# Linux examples: /dev/ttyUSB0, /tmp/ttyV0 (virtual)
# Windows examples: COM3, COM4
ECU_SERIAL_PORT=/tmp/ttyV0
ECU_BAUD_RATE=10400

# OEM behavior profile: generic | vag | toyota | honda
ECU_PROFILE=generic

# Logging: debug | info | warn | error
LOG_LEVEL=info

# Gateway WebSocket port (cloud-gateway app)
GATEWAY_PORT=8080

# Timing jitter percentage (0.0 - 0.5, default 0.15 = 15%)
TIMING_JITTER=0.15

# Security: disable for dev/CI, enable for prod-like testing
ECU_SECURITY_ENABLED=true
